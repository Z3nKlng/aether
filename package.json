{
  "name": "aether",
  "private": true,
  "packageManager": "pnpm@11.4.0",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "clean": "turbo clean && rm -rf node_modules"
  },
  "devDependencies": {
    "turbo": "^2.9.15",
    "prettier": "^3.8.3"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}